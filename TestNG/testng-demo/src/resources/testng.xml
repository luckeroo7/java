<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    ================================================================
    testng.xml — главный конфигурационный файл TestNG
    ================================================================

    Иерархия:
      <suite>       — весь набор тестов
        <test>      — логическая группа (не метод, а тег-контейнер!)
          <classes> — тест-классы, включённые в эту группу
          <groups>  — управление группами для этого <test>

    Ключевые атрибуты <suite>:
      name          — имя сьюта (отображается в отчётах)
      parallel      — режим параллелизма: methods | classes | tests | instances
      thread-count  — максимальное число потоков
      verbose       — уровень вывода (0-10), 2 — стандартный

    Запуск: mvn test  или  java -cp ... org.testng.TestNG testng.xml
    ================================================================
-->

<suite name="TestNG-Demo-Suite"
       parallel="methods"
       thread-count="4"
       verbose="2">

    <!-- ============================================================
         Глобальные Listeners: подключаются ко всему сьюту
         ============================================================ -->
    <listeners>
        <listener class-name="com.example.listeners.CustomTestListener"/>
        <!-- GlobalRetryTransformer добавит RetryAnalyzer ко всем тестам:
        <listener class-name="com.example.retry.GlobalRetryTransformer"/> -->
    </listeners>

    <!-- ============================================================
         TEST 1: Аннотации и жизненный цикл
         ============================================================ -->
    <test name="Lifecycle-and-Annotations">
        <classes>
            <class name="com.example.basics.AnnotationLifecycleTest"/>
            <class name="com.example.basics.TestAttributesTest"/>
            <class name="com.example.basics.DependencyTest"/>
        </classes>
    </test>

    <!-- ============================================================
         TEST 2: DataProvider — параметризованные тесты
         ============================================================ -->
    <test name="DataProvider-Tests">
        <classes>
            <class name="com.example.dataprovider.DataProviderTest"/>
        </classes>
    </test>

    <!-- ============================================================
         TEST 3: Группы тестов
         Запускаем только smoke- и regression-группы;
         исключаем brokenTests (если бы они были)
         ============================================================ -->
    <test name="Groups-Demo">
        <groups>
            <run>
                <!-- <exclude name="brokenTests"/> -->
                <include name="smoke"/>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="com.example.groups.GroupsTest"/>
        </classes>
    </test>

    <!-- ============================================================
         TEST 4: Параллельное выполнение
         parallel="methods" унаследован от <suite>
         ============================================================ -->
    <test name="Parallel-Tests">
        <classes>
            <class name="com.example.parallel.ParallelMethodsTest"/>
        </classes>
    </test>

    <!-- ============================================================
         TEST 5: Assertions — жёсткие и мягкие проверки
         ============================================================ -->
    <test name="Assertions-Demo">
        <classes>
            <class name="com.example.assertions.AssertionsTest"/>
        </classes>
    </test>

    <!-- ============================================================
         TEST 6: @Factory — фабрика тест-объектов
         ============================================================ -->
    <test name="Factory-Demo">
        <classes>
            <class name="com.example.factory.UserRoleTest"/>
        </classes>
    </test>

    <!-- ============================================================
         TEST 7: Retry Analyzer — перезапуск упавших тестов
         ============================================================ -->
    <test name="Retry-Demo">
        <classes>
            <class name="com.example.retry.RetryDemoTest"/>
        </classes>
    </test>

    <!-- ============================================================
         TEST 8: Listeners
         ============================================================ -->
    <test name="Listeners-Demo">
        <classes>
            <class name="com.example.listeners.ListenerDemoTest"/>
        </classes>
    </test>

</suite>
