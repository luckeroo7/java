<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="16" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="logic.Slide11Controller" styleClass="root slide-root demo-card">
    <children>
        <Label text="Particle Timeline" styleClass="label-title" wrapText="true" maxWidth="1500"/>
        <HBox alignment="CENTER" spacing="16" maxWidth="1500">
            <children>
                <VBox alignment="CENTER_LEFT" spacing="12" styleClass="content-box" prefWidth="430">
                    <children>
                        <Label text="Timeline управляет изменением данных во времени" styleClass="label-subtitle" wrapText="true"/>
                        <Label text="Нажмите «Поток частиц»: каждая частица — обычный Node. Контроллер меняет координаты, прозрачность и размер, а сцена сама перерисовывается." styleClass="label-content" wrapText="true"/>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <children>
                                <Button text="Поток частиц" onAction="#burst" styleClass="demo-button"/>
                                <ToggleButton fx:id="autoButton" text="Автопоток" onAction="#toggleAuto" styleClass="demo-button"/>
                                <Button text="Очистить" onAction="#clear" styleClass="demo-button"/>
                            </children>
                        </HBox>
                        <ProgressBar fx:id="activityBar" progress="0" maxWidth="Infinity"/>
                        <Label fx:id="counterLabel" text="Частиц: 0" styleClass="label-hint" wrapText="true"/>
                        <Label text="Timeline + KeyFrame = регулярные изменения сцены" styleClass="label-code" wrapText="true"/>
                    </children>
                </VBox>
                <Pane fx:id="particlePane" styleClass="content-box particle-stage" prefWidth="860" prefHeight="430" minHeight="360"/>
            </children>
        </HBox>
    </children>
</VBox>
