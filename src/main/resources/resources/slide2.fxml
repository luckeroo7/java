<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="18" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" styleClass="root slide-root">
    <children>
        <Label text="Где JavaFX уместен сегодня" styleClass="label-title" wrapText="true" maxWidth="1500"/>
        <HBox alignment="CENTER" spacing="18" maxWidth="1500">
            <children>
                <VBox alignment="TOP_LEFT" spacing="10" styleClass="content-box half-box">
                    <children>
                        <Label text="Силен" styleClass="label-subtitle"/>
                        <Label text="• Desktop-rich-client на Java" styleClass="label-content" wrapText="true"/>
                        <Label text="• Внутренние системы и панели управления" styleClass="label-content" wrapText="true"/>
                        <Label text="• Таблицы, графики, формы, локальная логика" styleClass="label-content" wrapText="true"/>
                    </children>
                </VBox>
                <VBox alignment="TOP_LEFT" spacing="10" styleClass="content-box half-box">
                    <children>
                        <Label text="Требует реализма" styleClass="label-subtitle"/>
                        <Label text="• Это не замена браузеру для публичного веба" styleClass="label-content" wrapText="true"/>
                        <Label text="• JDK и JavaFX версии нужно выбирать явно" styleClass="label-content" wrapText="true"/>
                        <Label text="• WebView/media лучше проверять заранее" styleClass="label-content" wrapText="true"/>
                    </children>
                </VBox>
            </children>
        </HBox>
        
    </children>
</VBox>
