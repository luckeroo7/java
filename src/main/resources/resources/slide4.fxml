<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="18" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" styleClass="root slide-root">
    <children>
        <Label text="Scene Graph: скелет интерфейса" styleClass="label-title" wrapText="true" maxWidth="1500"/>
        <HBox alignment="CENTER" spacing="16" styleClass="flow-box">
            <children>
                <Label text="Stage" styleClass="flow-node"/>
                <Label text="→" styleClass="label-subtitle"/>
                <Label text="Scene" styleClass="flow-node"/>
                <Label text="→" styleClass="label-subtitle"/>
                <Label text="Root" styleClass="flow-node"/>
                <Label text="→" styleClass="label-subtitle"/>
                <Label text="Nodes" styleClass="flow-node"/>
            </children>
        </HBox>
        <VBox alignment="CENTER_LEFT" spacing="12" maxWidth="1500" styleClass="content-box">
            <children>
                <Label text="• UI — дерево объектов Node, где контейнеры управляют размещением" styleClass="label-content" wrapText="true" maxWidth="1500"/>
                <Label text="• CSS применяется к узлам этого дерева через Scene и Parent" styleClass="label-content" wrapText="true" maxWidth="1500"/>
                <Label text="• FXML описывает то же дерево декларативно, контроллер добавляет поведение" styleClass="label-content" wrapText="true" maxWidth="1500"/>
            </children>
        </VBox>
    </children>
</VBox>
